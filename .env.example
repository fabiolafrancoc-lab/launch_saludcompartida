# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno — www.saludcompartida.app
# Copia este archivo a .env.local para desarrollo local (NUNCA subas .env.local)
# En producción: Vercel → proyecto → Settings → Environment Variables
#
# Guía completa de dónde obtener cada valor: README.md §1-§5
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase MAIN  ───────────────────────────────────────────────────────────
# Proyecto: mvp-saludcompartida  |  Tabla: registrations
# Project URL: supabase.com → proyecto mvp-saludcompartida → Project Settings → Custom Domains
# Service role key: supabase.com → proyecto → Project Settings → Data API → fila "service_role"
#   ⚠️  Es diferente a la anon key — es el token de la fila que dice exactamente "service_role"
SUPABASE_URL_MAIN=https://api.saludcompartida.app
SUPABASE_SERVICE_ROLE_KEY_MAIN=******

# ── Supabase ALT  (solo si tienes órdenes anteriores al formulario /api/registro)
# Proyecto: launch-saludcompartida  |  Tabla: shopify_orders
# Dónde: supabase.com → proyecto launch-saludcompartida → Project Settings → Data API
# Si no necesitas el fallback legacy, deja estas líneas vacías o elimínalas.
SUPABASE_URL_ALT=https://imndmmbtsllyssvokdlh.supabase.co
SUPABASE_SERVICE_ROLE_KEY_ALT=******

# ── Shopify webhook secret ───────────────────────────────────────────────────
# Dónde: Shopify Admin → Configuración → Notificaciones → Webhooks
#   → Crear webhook: evento "orders/paid", URL "https://www.saludcompartida.app/api/webhooks/shopify"
#   → Después de guardar, Shopify muestra el Signing Secret (shpss_...)
#   → ⚠️ Solo se muestra una vez — copiarlo inmediatamente
SHOPIFY_WEBHOOK_SECRET=shpss_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── CORS para /api/registro ──────────────────────────────────────────────────
# Dominio de tu tienda Shopify. Permite que el formulario llame a /api/registro.
SHOPIFY_STORE_ORIGIN=https://www.saludcompartida.shop

# ── Resend (envío de emails con los códigos de acceso) ───────────────────────
# Dónde la API key: resend.com → API Keys → Create API Key (Permission: Full access)
# La key empieza con re_...
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Email remitente — debe ser un dominio verificado en Resend
# Dónde verificar: resend.com → Domains → Add Domain → seguir instrucciones DNS
# Si aún no verificaste el dominio, usa "onboarding@resend.dev" solo para pruebas
RESEND_FROM_EMAIL=noreply@saludcompartida.app

