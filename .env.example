# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno requeridas en Vercel → Settings → Environment Variables
# Copia este archivo a .env.local para desarrollo local (NUNCA subas .env.local)
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase MAIN  (proyecto: mvp-saludcompartida) ───────────────────────────
# Usado por /api/registro y /api/validar-codigo para la tabla `registrations`
SUPABASE_URL_MAIN=https://XXXXXXXXXXXXXXXXXX.supabase.co
SUPABASE_SERVICE_ROLE_KEY_MAIN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Supabase ALT  (proyecto: launch-saludcompartida) ─────────────────────────
# Usado por /api/validar-codigo como fallback para la tabla `shopify_orders`
# (órdenes antiguas que llegaron antes de implementar /api/registro)
SUPABASE_URL_ALT=https://YYYYYYYYYYYYYYYYYY.supabase.co
SUPABASE_SERVICE_ROLE_KEY_ALT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Públicas (client-side) ───────────────────────────────────────────────────
# Solo necesitan permiso anon — NO son la service role key
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Shopify webhook ──────────────────────────────────────────────────────────
# Secreto para verificar que el webhook viene de Shopify.
# Encontrar en: Shopify Admin → Configuración → Notificaciones → Webhooks
#   → después de crear el webhook "Pago de pedido", Shopify muestra el "Signing Secret"
SHOPIFY_WEBHOOK_SECRET=tu_shopify_webhook_secret_aqui

# ── CORS para /api/registro ──────────────────────────────────────────────────
# Dominio de tu tienda Shopify. Permite que el formulario Shopify llame a /api/registro.
# Ejemplo: https://tu-tienda.myshopify.com  o  https://tu-dominio-shopify.com
SHOPIFY_STORE_ORIGIN=https://tu-tienda.myshopify.com

# ── Resend (envío de emails) ─────────────────────────────────────────────────
# API key de Resend para enviar emails de bienvenida con los códigos.
# Obtener en: https://resend.com/api-keys
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Email remitente (debe ser un dominio verificado en Resend)
RESEND_FROM_EMAIL=noreply@saludcompartida.app
